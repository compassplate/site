{
  "buildCommand": "echo 'No build needed for static + serverless functions'",
  "installCommand": "echo 'No dependencies to install'",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "VITE_SUPABASE_URL": "@VITE_SUPABASE_URL",
    "VITE_SUPABASE_KEY": "@VITE_SUPABASE_ANON_KEY",
    "VITE_TMDB_API_KEY": "@VITE_TMDB_API_KEY"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
